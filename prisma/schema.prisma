generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// userId in all models is the UUID from Supabase auth.users — no Prisma relation
// needed since auth lives in a separate schema. Application code always filters
// by userId; RLS policies add a second layer of protection.

model UserProfile {
  userId              String   @id @db.Uuid
  displayName         String?
  timezone            String   @default("UTC")
  defaultCycleLength  Int      @default(28)
  defaultPeriodLength Int      @default(5)
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PeriodLog {
  id              String   @id @default(cuid())
  userId          String   @db.Uuid
  periodStartDate String
  periodEndDate   String?
  symptoms        Json?
  mood            String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, periodStartDate])
}

model PrivacySettings {
  userId         String   @id @db.Uuid
  analyticsOptIn Boolean  @default(false)
  reminderOptIn  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
